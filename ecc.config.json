{
  "version": 1,
  "description": "Personal ecc branch config — selective skill deployment",
  "deploy_target": "~/.claude",
  "installer_modules": [
    "rules-core",
    "agents-core",
    "commands-core",
    "hooks-runtime",
    "platform-configs",
    "workflow-quality",
    "agentic-patterns",
    "research-apis",
    "devops-infra",
    "orchestration"
  ],
  "installer_target": "claude",
  "exclude_rules": [
    "csharp",
    "dart",
    "java",
    "kotlin",
    "perl",
    "php",
    "swift"
  ],
  "remove_legacy_shims": [
    "agent-sort.md",
    "claw.md",
    "context-budget.md",
    "devfleet.md",
    "docs.md",
    "e2e.md",
    "eval.md",
    "orchestrate.md",
    "prompt-optimize.md",
    "rules-distill.md",
    "tdd.md",
    "verify.md"
  ],
  "skill_renames": {
    "everything-claude-code": "ecc"
  },
  "exclude_skills": [
    "android-clean-architecture",
    "carrier-relationship-management",
    "compose-multiplatform-patterns",
